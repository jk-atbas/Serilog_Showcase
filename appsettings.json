{
	// {Message:lj} - Strings ohne Quotes, komplexe Objekte als JSON
	// {Message:j} - Alles als JSON (auch Strings in Quotes)
	// {Message:l} - Alles als Literals (auch Objekte als ToString)
	// {Message} - Serilog-Default (Strings in Quotes)
	"Serilog": {
		"Using": [
			"Serilog.Sinks.Async",
			"Serilog.Sinks.Console",
			"Serilog.Sinks.File",
			"Serilog.Enrichers.Environment",
			"Serilog.Enrichers.Thread",
			"Serilog.Enrichers.Process",
			"Serilog.Expressions"
		],

		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Warning",
				"Microsoft.Hosting.Lifetime": "Information",
				"System": "Warning",
				"SerilogShowcase.Services.NoisyService": "Warning",
				"SerilogShowcase.Services.OrderService": "Debug"
			}
		},

		"WriteTo": [
			{
				"Name": "Console",
				"Args": {
					"theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
					"outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine} {Message:lj} {Properties:j}{NewLine}{Exception}{NewLine}"
				}
			},
			{
				"Name": "Async",
				"Args": {
					"configure": {
						"Args": {
							"Name": "File",
							"path": "logs/serilog-showcase-.log",
							"rollingInterval": "Day",
							"retainedFileCountLimit": 7,
							"fileSizeLimitBytes": 10485760,
							"outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] [Thread:{ThreadId}] {Message:lj} {Properties:j}{NewLine}{Exception}"
						}
					}
				}
			},
			{
				"Name": "Async",
				"Args": {
					"configure": {
						"Args": {
							"Name": "File",
							"path": "logs/errors-.log",
							"rollingInterval": "Day",
							"retainedFileCountLimit": 30,
							"restrictedToMinimumLevel": "Error",
							"outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Properties:j}{NewLine}{Exception}"
						}
					}
				}
			}
		],

		"Filter": [
			{
				"Name": "ByExcluding",
				"Args": {
					"expression": "Contains(@Message, 'HealthCheck')"
				}
			}
		],

		"Enrich": [
			"FromLogContext",
			"WithMachineName",
			"WithThreadId",
			"WithProcessId"
		],

		"Properties": {
			"Application": "SerilogShowcase",
			"Environment": "Development"
		}
	},

	"ConnectionStrings": {
		"DefaultConnection": "Server=localhost;Database=ShowcaseDb;User Id=sa;Password=SuperSecret123!;TrustServerCertificate=true"
	},

	"AppSettings": {
		"ApiKey": "sk-live-abc123def456ghi789",
		"CustomerServiceEmail": "support@example.com"
	}
}
